FROM node:22-bookworm-slim AS builder

WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY tsconfig.base.json tsconfig.json ./
COPY artifacts ./artifacts
COPY lib ./lib
COPY scripts ./scripts

# --frozen-lockfile は pnpm-workspace.yaml の overrides と lockfile の記録が完全一致しないと失敗する。
# コンテナ内の pnpm バージョンや将来の設定差分に備え、Docker ビルドではロックを再解決する。
RUN pnpm install --no-frozen-lockfile

ENV PORT=5173
ENV BASE_PATH=/
RUN pnpm --filter @workspace/horse-racing run build

FROM nginx:1.27-alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/artifacts/horse-racing/dist/public /usr/share/nginx/html
EXPOSE 80
